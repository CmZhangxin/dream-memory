# Dream Memory 环境变量配置

# ─── Memory Gateway ──────────────────────────────
# Memory Gateway 地址（默认本地）
GATEWAY_URL=http://localhost:8420

# ─── Obsidian Vault（Dashboard 用） ──────────────
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# ─── Cron 调度 ───────────────────────────────────
# 每天 23:00 自动触发 L0→L1→L2→L3 升华
CRON_SCHEDULE=0 23 * * *
CRON_TIMEZONE=Asia/Shanghai
# CRON_ENABLED=false  # 可选：禁用 cron-runner

# ─── LLM 配置（必填，否则升华失败） ───────────────
# Gateway 用这些变量调用 LLM 提取 L1/L2/L3。
# 也可改写到 ~/.dream-memory/tdai-memory-openclaw-plugin/tdai-gateway.yaml 里。
#
# 推荐：硅基流动 SiliconFlow + DeepSeek-V3
TDAI_LLM_BASE_URL=https://api.siliconflow.cn/v1
TDAI_LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TDAI_LLM_MODEL=deepseek-ai/DeepSeek-V3
# TDAI_LLM_MAX_TOKENS=4096
# TDAI_LLM_TIMEOUT_MS=120000

# ─── Embedding 配置（建议与 LLM 同 key） ─────────
# 可省略，默认从 yaml 读
# TDAI_EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
# TDAI_EMBEDDING_API_KEY=sk-xxxxxxxx
# TDAI_EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
